# Sao chép thành .env.production HOẶC chạy: .\deploy-hosting.ps1 -ApiBaseUrl "https://..."
# Chỉ gốc URL backend (HTTPS), KHÔNG thêm /api — code đã gọi /api/...
# Sau khi deploy backend, CORS trên server phải có:
#   https://banvexe-web-app-41f61.web.app
#   https://banvexe-web-app-41f61.firebaseapp.com
VITE_API_BASE_URL=https://YOUR-BACKEND-HOST.example.com
